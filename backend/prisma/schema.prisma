generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

// ---------- MODELS ----------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  isProvider   Boolean  @default(false)
  isClient     Boolean  @default(true)
  createdAt    DateTime @default(now())

  services       Service[]
  ordersAsClient Order[]   @relation("ClientOrders")
  messages       Message[]
  reviews        Review[]

  @@map("users")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  services Service[]

  @@map("categories")
}

model Service {
  id           String   @id @default(uuid())
  providerId   String
  provider     User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  title        String
  description  String
  price        Decimal  @db.Decimal(10, 2)
  deliveryDays Int
  images       String[]
  createdAt    DateTime @default(now())

  orders Order[]

  @@map("services")
}

model Order {
  id        String      @id @default(uuid())
  clientId  String
  client    User        @relation("ClientOrders", fields: [clientId], references: [id])
  serviceId String
  service   Service     @relation(fields: [serviceId], references: [id])
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  messages Message[]
  review   Review?

  @@map("orders")
}

model Message {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("messages")
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("reviews")
}